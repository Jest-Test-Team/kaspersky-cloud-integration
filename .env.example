# Generate at https://opentip.kaspersky.com/token/
KASPERSKY_TIP_API_KEY=

KASPERSKY_TIP_BASE_URL=https://opentip.kaspersky.com/api/v1

# Kaspersky Next / Endpoint Security Cloud workspace OR on-prem KSC 15.2 Open API.
# Cloud console gateway: https://<workspace>.cloud.kaspersky.com:8080
# On-prem Administration Server: https://<host>:13299
KSC_BASE_URL=https://localhost:13299
# On-prem KSC only: account+password auto-login. The backend calls
# Session.StartSession (KSCBasic), caches the session token, and re-logs in on
# expiry. NOTE: the s405 cloud console does NOT accept this (use KSC_ACCESS_TOKEN).
KSC_LOGIN=
KSC_PASSWORD=
# internal="1" for an internal KSC user, "0" for a domain user.
KSC_INTERNAL=1
# Cloud console: OAuth Bearer JWT access token (auto-prefixed with "Bearer ").
KSC_BEARER_TOKEN=
# On-prem KSC: raw Authorization scheme, e.g. "KSCT <token>", "KSCWT <web-token>",
# or "KSCBasic user=\"<b64-login>\", pass=\"<b64-pass>\", internal=\"1\"".
KSC_AUTHORIZATION=
# Alternatively, an existing session id sent via the X-KSC-Session header.
KSC_SESSION=
# Kaspersky Next / ES Cloud console: the gateway reads the JWT from the
# `access_token` cookie (it ignores Authorization: Bearer). Easiest option —
# paste just the access_token JWT (sent as "Cookie: access_token=<jwt>").
# Tokens are short-lived (~1 hour); refresh by re-copying from the browser.
KSC_ACCESS_TOKEN=
# Or paste a full raw Cookie header string (wins over KSC_ACCESS_TOKEN):
KSC_COOKIE=
KSC_XSRF_TOKEN=
# Base64-encoded virtual server name (optional).
KSC_VSERVER=
# Set true only when the Administration Server presents a self-signed certificate.
KSC_INSECURE_SKIP_VERIFY=false

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
